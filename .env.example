# Copy to `.env` next to docker-compose.prod.yml, then fill in secrets.
# Usage: docker compose --env-file .env -f docker-compose.prod.yml up -d


# Public URLs (required - no defaults in compose)

# Browser origin of the SPA (CORS / ORIGIN_URL for the API). Include scheme, no trailing slash.
# Example: https://app.example.edu.il
SERVICE_URL_CLIENT=

# API base URL baked into the client build (VITE_API_URL). Must be reachable from users' browsers.
# Use your public API URL or same-origin path if you terminate TLS on a reverse proxy.
# Example: https://api.example.edu.il  or  https://app.example.edu.il/api
SERVICE_URL_SERVER=


# PostgreSQL (defaults shown match docker-compose.prod.yml)

POSTGRES_USER=postgres
POSTGRES_DB=student_personalizer
POSTGRES_PASSWORD=change-me-strong-password


# API server - auth & crypto (required in prod compose; generate strong values)

# Long random string for signing JWTs (e.g. openssl rand -hex 32)
JWT_SECRET_KEY=

# Base64-encoded 32-byte AES key for field-level PII encryption (e.g. openssl rand -base64 32)
FIELD_ENCRYPTION_KEY=

# Secret pepper for student ID search hashes (long random string; keep stable once in use)
HASH_PEPPER=


# API server - optional overrides (defaults in compose)

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_HOURS=8
INACTIVITY_TIMEOUT_MINUTES=30

# Set true if Postgres requires TLS from the app (e.g. managed DB)
DB_SSL_REQUIRED=false
