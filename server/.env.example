PORT=3000
ORIGIN_URL=http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/student_personalizer
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Auth cookies: refresh token is httpOnly. Production should serve the SPA and /api under one site
# (reverse proxy) so SameSite=Lax works. Split origins (app + api subdomains) need
# COOKIE_SAMESITE=none and COOKIE_SECURE=true plus a CSRF strategy.
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# REFRESH_COOKIE_PATH=/api
# REFRESH_TOKEN_BODY_FALLBACK=false

# Optional: VirusTotal scan gate for uploads
# VIRUSTOTAL_API_KEY=